# Postgres Database (Neon)
# Auto-set by Vercel if using Neon marketplace integration
# Or get from https://neon.tech → your project → Connection Details
POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require

# Google OAuth2 Credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# OAuth2 Refresh Token (covers both Gmail + Drive scopes)
# Generate at: https://developers.google.com/oauthplayground
# Scopes needed: gmail.send + drive.file
GOOGLE_REFRESH_TOKEN=1//your-refresh-token

# Email address to send verification emails from
GMAIL_FROM=support@yourdomain.com

# Google Drive folder ID for storing signed PDFs
# Get from folder URL: https://drive.google.com/drive/folders/THIS_IS_THE_ID
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Admin panel password (access at /admin)
ADMIN_PASSWORD=your-secure-password
